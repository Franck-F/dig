# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# But always commit the example template so new contributors know what to fill.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code workspace (local agent settings, specs, scheduled tasks)
.claude/

# Anthropic skills bundles (tooling cache, not part of the app)
/skills/

# RGPD — instantiated DPA contracts and AIPD drafts containing signatures
# or third-party identifiers are kept out of the repo. Templates and the
# registry stay committed.
docs/rgpd/dpa/
docs/rgpd/aipd-*.draft.md
