# Copy this file to `.env.local` and fill in real values. `.env.local` is git-ignored.

# ── Database (Postgres / Supabase) ───────────────────────────────────────
# Pooled connection (PgBouncer) for app runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for `prisma migrate` / `prisma db push`
DIRECT_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres"

# ── Auth.js / NextAuth v5 ────────────────────────────────────────────────
# REQUIRED. Generate a secure 32-byte base64 secret with one of:
#   openssl rand -base64 32
#   npx auth secret
#   (PowerShell) [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Max 256}))
# Never commit a real value. Rotate on suspected leak (invalidates all sessions).
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# ── Optional OAuth providers (leave empty to disable each) ───────────────
# When env vars for a provider are missing, the corresponding social button
# on /login is rendered disabled with a "bientôt" tooltip. No partial config
# is supported — both ID and SECRET must be set together.

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://digizelle.fr/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
# Authorisation callback URL: https://digizelle.fr/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Discord OAuth — free. Create an app at https://discord.com/developers/applications
# OAuth2 → Redirects: http://localhost:3000/api/auth/callback/discord  (et le domaine prod)
# OAuth2 → Scopes recommandés: identify, email
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ── Email (Resend) ───────────────────────────────────────────────────────
# Used for: contact form forwarding, signup email-verification codes,
# password-reset codes. When unset, all email sends are mocked to stdout
# (codes printed in dev terminal); contact submissions still persist to DB.
# https://resend.com/api-keys
RESEND_API_KEY=""
CONTACT_TO_EMAIL="contact@digizelle.fr"

# RGPD / DPO contact, surfaced in 13+ user-facing copies (charte,
# politique de confidentialité, désabonnement newsletter, suppression
# de compte, message de verrouillage 2FA, footer mailings, …). Centralisé
# via `src/lib/contact.ts#getDpoEmail()` — flipper cette valeur ici met
# à jour toutes les surfaces d'un coup. Fallback : `contact@digizelle.fr`
# (l'association n'opère qu'une seule adresse fonctionnelle).
DPO_EMAIL=""

# Resend webhook signing secret — get it from
#   Resend dashboard → Webhooks → <your endpoint> → Signing secret
# Looks like `whsec_<base64>`. /api/webhooks/resend uses it to verify
# Svix-style signatures (svix-id + svix-timestamp + body, HMAC-SHA256).
# Without this set the webhook returns 503; emails still send fine but
# bounces / complaints aren't recorded.
RESEND_WEBHOOK_SECRET=""

# ── Cron (Vercel Cron) ───────────────────────────────────────────────────
# Required to authorise calls to /api/cron/* routes.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ── Sentry (errors + perf monitoring) ────────────────────────────────────
# DSN copied from Sentry → Project Settings → Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser — that's by design
# (DSNs are public, they're just identifiers). SENTRY_DSN is the
# server-only fallback name read by the same SDK.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# Source-map upload during build (Sentry → Settings → Auth Tokens).
# Without it the SDK still works, but stack traces show minified code.
# Required scopes: `project:releases`, `project:read`.
SENTRY_AUTH_TOKEN=""

# ── Upstash Redis (rate-limit, multi-instance) ────────────────────────────
# When BOTH variables are set, the rate-limiter (auth + per-user
# self-service) switches from in-memory token bucket to a Redis-backed
# fixed window. Without them, rate-limiting still works but each Vercel
# instance has its own counter — fine for dev, weakens the limit by N×
# in production behind autoscaling.
#
# Provision a free Upstash Redis db at https://console.upstash.com,
# region EU-WEST-1 to keep latency low from the Vercel CDG region.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Supabase Storage (image uploads) ──────────────────────────────────────
# When BOTH variables are set, image uploads (avatars, mentor photos,
# challenge covers, post attachments) stream the bytes to Supabase
# Storage and persist a public URL in Postgres instead of the data URI.
# Without them, the legacy in-DB data-URI path is used (works fine in
# dev, but bloats the row payload — keep that for local-only).
#
# In the Supabase dashboard, create four PUBLIC buckets named exactly:
#   avatars, mentor-photos, challenge-covers, post-attachments
# (no RLS needed for the service role; the route layer enforces auth).
#
# SUPABASE_URL is the project URL — e.g. https://abcdefgh.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the SERVICE_ROLE secret (NEVER expose to
# the browser). Both are visible in Settings → API.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── CSP enforcement gate ──────────────────────────────────────────────────
# Set to "1" to flip the Content-Security-Policy header from
# "Report-Only" (collect violations, don't block) to enforced (block
# violations). The Sentry CSP-report stream should be quiet for a full
# week before flipping — see docs/ops/csp-enforcement.md for the
# bake-in checklist.
CSP_ENFORCE=""
